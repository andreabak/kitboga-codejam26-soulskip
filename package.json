    "@prettier/plugin-oxc": "^0.1.3",
    "@types/node": "^22.x",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "serve": "^14.2.6",
    "typescript": "^5.x",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.x"
  }
