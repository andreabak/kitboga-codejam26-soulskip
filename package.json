  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently \"npm run dev-build\" \"npm run dev-server\"",
    "dev-build": "vite build --watch --mode development",
    "dev-server": "serve . -p 8135",
    "lint": "eslint --fix src",
    "format": "prettier --write 'src/**/*.{css,htm,html,js,jsx,mjs,cjs,ts,tsx,svelte,json,less,scss}'",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
